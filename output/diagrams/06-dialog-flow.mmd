---
config:
  theme: base
  themeVariables:
    primaryColor: "#EEF2FF"
    primaryTextColor: "#1E293B"
    primaryBorderColor: "#1E3A8A"
    lineColor: "#64748B"
    fontFamily: "PingFang TC, Microsoft JhengHei, sans-serif"
---
flowchart TD
    A["客戶進入"] --> B["意圖識別"]
    B --> C1["詢價"]
    B --> C2["訂單追蹤"]
    B --> C3["閒聊 / 其他"]

    C1 --> D["舊客比對"]
    C2 --> E["查詢訂單 DB"]

    D --> F{"舊客 / 新客"}
    F -->|"舊客"| G1["帶入資料"]
    F -->|"新客"| G2["建立 Session"]

    G1 --> H["欄位缺口偵測"]
    G2 --> H

    H --> I["生成下一個白話追問"]
    I --> J["客戶回應"]
    J --> K["解析填入欄位"]
    K --> L{"欄位是否完整？"}
    L -->|"否"| H
    L -->|"是"| M{"觸發模擬圖？"}

    M -->|"是"| N["生成貼標情境圖"]
    M -->|"否"| O["訂單草稿確認"]
    N --> O

    O --> P["輸出 JSON + 通知業務"]
    P --> Q["等待業務確認訂單成立"]

    style A fill:#DBEAFE,stroke:#1E40AF
    style B fill:#FEF3C7,stroke:#C9A84C,color:#92400E
    style H fill:#E2E8F0,stroke:#475569,color:#334155
    style Q fill:#D1FAE5,stroke:#059669,color:#065F46
