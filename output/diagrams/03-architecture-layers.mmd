---
config:
  theme: base
  themeVariables:
    primaryColor: "#F1F5F9"
    primaryTextColor: "#1E293B"
    primaryBorderColor: "#1E3A8A"
    lineColor: "#64748B"
    fontFamily: "PingFang TC, Microsoft JhengHei, sans-serif"
---
flowchart TB
    subgraph L1 ["使用者層 (User Layer)"]
      direction LR
      U1["網頁對話框<br/>(POC 主要)"]
      U2["LINE 頻道<br/>(Phase 2)"]
      U3["管理後台<br/>(數據 / 接管)"]
    end

    subgraph L2 ["對話層 (Conversation Layer)"]
      direction TB
      C1["路由器(統一入口)"]
      C2["Session 管理"]
      C3["意圖識別<br/>詢價 / 訂單追蹤 / 補印 / 閒聊 / 轉接"]
      C4["轉接處理<br/>情緒偵測 → Email 通知真人"]
      C1 --> C2 --> C3 --> C4
    end

    subgraph L3 ["AI 核心 (AI Core)"]
      direction TB
      A1["★ 訂單資料引導引擎<br/>(Field Gap Detection)"]
      A2["LLM 語言模型 / 知識庫 RAG / Prompt 引擎 / 圖像分析"]
      A1 --> A2
    end

    subgraph L4 ["資料層 (Data Layer)"]
      direction LR
      D1["訂單草稿 DB"]
      D2["客戶資料庫"]
      D3["知識庫"]
      D4["對話紀錄"]
    end

    L1 --> L2 --> L3 --> L4

    style L1 fill:#EEF2FF,stroke:#1E3A8A
    style L2 fill:#FEF3C7,stroke:#C9A84C
    style L3 fill:#E2E8F0,stroke:#475569
    style L4 fill:#D1FAE5,stroke:#059669
